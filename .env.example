# ============================================================
# 2026_TV — 환경변수 템플릿 (.env.example)
# 실제 값은 이 파일을 복사하여 .env 파일을 생성하고 입력하세요.
# .env 파일은 절대 Git에 커밋하지 마세요.
# ============================================================

# ── 배포 서버 정보 ─────────────────────────────────────────
SERVER_IP=YOUR_SERVER_IP
SSH_PORT=22
SSH_USER=YOUR_SSH_USER
SSH_PASSWORD=                       # 실제 SSH 패스워드 입력

# ── PostgreSQL (외부 운영 중, 공통 DB) ─────────────────────
DB_HOST=YOUR_DB_HOST_IP
DB_PORT=5432
DB_NAME=YOUR_DB_NAME
DB_USER=YOUR_DB_USER
DB_PASSWORD=                        # 실제 DB 패스워드 입력

# SQLAlchemy async 연결 URL (자동 구성)
DATABASE_URL=postgresql+asyncpg://YOUR_DB_USER:YOUR_PASSWORD@YOUR_DB_HOST_IP:5432/YOUR_DB_NAME

# psycopg2 동기 연결 URL (배치 작업용)
DATABASE_SYNC_URL=postgresql://YOUR_DB_USER:YOUR_PASSWORD@YOUR_DB_HOST_IP:5432/YOUR_DB_NAME

# ── Redis ──────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ── 서비스 포트 ─────────────────────────────────────────────
FRONTEND_PORT=3000
BACKEND_API_PORT=8000
NLP_API_PORT=8001

# ── CORS 설정 ───────────────────────────────────────────────
# 예: http://YOUR_SERVER_IP:3000,https://yourdomain.com
# 개발 환경에서는 * 사용 가능
CORS_ORIGINS=*

# ── Frontend 빌드 설정 ──────────────────────────────────────
# 브라우저가 실제로 API 요청을 보내는 주소 (서버 공인 IP/도메인)
NEXT_PUBLIC_API_URL=http://YOUR_SERVER_IP:8000
NEXT_PUBLIC_NLP_API_URL=http://YOUR_SERVER_IP:8001

# ── 생성형 AI API (FAST 광고 파이프라인) ────────────────────
# 이미지 생성 API (예: OpenAI DALL-E, Stability AI, 또는 기타)
IMAGE_GEN_API_KEY=                  # 이미지 생성 API 키
IMAGE_GEN_API_URL=                  # 이미지 생성 API 엔드포인트

# 비디오 생성 API (예: RunwayML, Kling, 또는 기타 무음 비디오 생성)
VIDEO_GEN_API_KEY=                  # 비디오 생성 API 키
VIDEO_GEN_API_URL=                  # 비디오 생성 API 엔드포인트

# ── FAST 광고 배치 설정 ─────────────────────────────────────
# 주 1회 실행 (cron 표현식: 매주 월요일 02:00 KST)
AD_BATCH_CRON=0 2 * * 1
# 금주 무료 VOD 선정 개수
WEEKLY_FREE_VOD_COUNT=10
# 개인화 무료 VOD 추천 개수
PERSONALIZED_VOD_COUNT=10

# ── NLP 추천 설정 ───────────────────────────────────────────
# KeyBERT 모델 (HuggingFace 모델명)
KEYBERT_MODEL=snunlp/KR-ELECTRA-discriminator
# 키즈·애니메이션 장르 코드 목록 (추천 가중치 적용 대상)
KIDS_GENRE_CODES=KIDS,ANIME,ANIMATION,어린이,애니메이션,키즈
# 키즈 가중치 부스트 점수 (0.0 ~ 1.0, 기본값 0.3)
KIDS_BOOST_SCORE=0.3

# ── 채널 설정 ───────────────────────────────────────────────
# 가상 채널 수
CHANNEL_COUNT=30
# 채널 전환 딜레이 (ms)
CHANNEL_ZAP_DELAY_MS=500

# ── 비전 AI 설정 (쇼핑 매칭) ────────────────────────────────
# YOLO 모델 경로 (컨테이너 내부 경로)
YOLO_MODEL_PATH=/app/models/yolov8n.pt
# 비전 분석 신뢰도 임계값
VISION_CONFIDENCE_THRESHOLD=0.5

# ── 파일 스토리지 ───────────────────────────────────────────
# FAST 광고 에셋 저장 경로 (컨테이너 내부 경로)
AD_ASSET_DIR=/app/data/ad_assets
# VOD 원본 파일 경로 (읽기 전용 마운트)
VOD_SOURCE_DIR=/app/data/vod

# ── 로깅 ────────────────────────────────────────────────────
LOG_LEVEL=INFO
# 환경 구분 (development / production)
APP_ENV=production
# 로그 파일 루트 디렉토리 (컨테이너 내부 경로, docker-compose 바인드 마운트와 일치)
# 서비스별 서브디렉토리 자동 생성: backend-api / nlp-api / ad-batch / frontend
LOG_DIR=/app/logs
# 로그 바인드 마운트 호스트 경로 (Windows: 드라이브 문자 + 포워드슬래시 사용)
# Windows 예시: LOG_ROOT=D:/20.WORKSPACE/2026_TV/logs
# Linux/Mac 예시: LOG_ROOT=./logs  (기본값, 생략 가능)
LOG_ROOT=D:/20.WORKSPACE/2026_TV/logs

